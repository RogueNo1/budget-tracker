{
  "name": "@budget-tracker/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "db:push": "drizzle-kit push --force",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@budget-tracker/core": "*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.29.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
